# Kafka advertised hostname (reachable from OUTSIDE Docker)
HOST_ADVERTISED=localhost

# Kafka port exposed to the host machine
HOST_KAFKA_PORT=9393

# Kafka topic and replay speed
TOPIC=bitcoin-stream
REPLAY_SPEED=50

# Spark worker resources
SPARK_WORKER_MEMORY=4G
SPARK_WORKER_CORES=3

# Kafka convenience setting
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
